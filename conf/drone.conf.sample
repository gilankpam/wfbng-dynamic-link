# /etc/dynamic-link/drone.conf
#
# Parsed by dl-applier at startup. key=value plaintext, one per line.
# '#' or ';' start a comment.

# ---- Listen endpoint for GS decision packets (over wfb-ng tunnel) ----
listen_addr = 0.0.0.0
listen_port = 5800

# ---- wfb_tx control socket (CMD_SET_FEC etc.) -----------------------
# Operational prereq: set `control_port = 8000` in the matching
# [tx] section of wfb-ng master.cfg. The default of 0 picks a
# random port at startup, which the applier can't target.
wfb_tx_ctrl_addr = 127.0.0.1
wfb_tx_ctrl_port = 8000

# The drone applies whatever the GS sends — there is no per-decision
# bounds check. Per-airframe fallback values are configured via safe_*
# below (used when the GS goes silent past health_timeout_ms).

# ---- IDR throttle ---------------------------------------------------
# Authoritative upper bound on keyframe rate. Lower bound: ~1 frame
# period (16.7 ms @ 60 fps). Higher = less bandwidth spent on
# keyframes, but longer corruption window after a missed primary.
min_idr_interval_ms = 500

# ---- Direction-aware apply stagger ----------------------------------
# When a decision changes the encoder bitrate, the applier splits the
# apply into two phases separated by this many milliseconds:
#   bitrate up   -> iw (power up) + tx_cmd first, then encoder.
#   bitrate down -> encoder first, then tx_cmd + iw (power down).
# The bottleneck is widened before the producer expands (and narrowed
# after the producer is throttled), avoiding a queue burst at the
# wfb-tx boundary during transitions. Set to 0 to disable.
apply_stagger_ms = 50

# ---- Sub-command pacing within an apply phase -----------------------
# Microseconds between consecutive sub-commands inside a single phase:
# the FEC/DEPTH/RADIO triplet inside dl_backend_tx_apply, and the
# tx<->radio (iw txpower) handoff inside the applier. Both CMD_SET_FEC
# and CMD_SET_INTERLEAVE_DEPTH trigger wfb-ng's refresh_session() which
# closes the open block, flushes the interleaver and re-broadcasts
# SESSION packets; back-to-back issues overlap those bursts and discard
# more in-flight video than necessary. 0 disables. Range 0..50 ms.
apply_sub_pace_ms = 5

# ---- OSD sink (msposd) ----------------------------------------------
osd_enable              = 1
osd_msg_path            = /tmp/MSPOSD.msg
osd_update_interval_ms  = 1000

# Debug OSD: per-apply-call latency stats (p50/p95/max/n/err) for the
# six parameter-change paths — FEC, DEPTH, RADIO, TXPWR, ENC, IDR.
# Off by default; flip to 1 on a single drone for diagnosis. Has no
# effect when osd_enable = 0 (no file is written at all in that case).
osd_debug_latency       = 0

# ---- GS-link watchdog (failsafe 1) ----------------------------------
# If no decision packet arrives for this long, push safe_defaults once
# and stop until a fresh decision arrives.
health_timeout_ms  = 10000
safe_k             = 8
safe_n             = 12
safe_depth         = 1
safe_mcs           = 1
safe_bandwidth     = 20
safe_tx_power_dBm  = 20
safe_bitrate_kbps  = 2000
# short_gi always false — pinned by the applier regardless of GS input.

# ---- Interleaver capability ----------------------------------------
# Whether the underlying wfb-ng supports the runtime
# CMD_SET_INTERLEAVE_DEPTH opcode. True only on the
# feat/interleaving_uep branch (vendored at drone/src/vendored/tx_cmd.h
# from upstream SHA 208ec1d).
#
# When 0:
#   - dl-applier never sends CMD_SET_INTERLEAVE_DEPTH.
#   - The drone reports DL_HELLO_FLAG_VANILLA_WFB_NG (bit 0 of the
#     HELLO flags byte); the GS pins depth=1 and short-circuits its
#     depth state machine.
#   - safe_depth above is harmless (never reaches wfb_tx).
#
# Mismatch warning: setting this to 1 against vanilla wfb_tx produces
# per-tick TX_APPLY_FAIL events on opcode 5 (visible via the debug
# log when debug_enable = 1).
interleaving_supported = 1

# ---- Backends -------------------------------------------------------
wlan_dev             = wlan0
# encoder_kind — one of: waybeam | majestic | none
encoder_kind         = majestic
encoder_host         = 127.0.0.1
encoder_port         = 80

# ---- MAVLink status channel (Phase 2) -------------------------------
# Drone → GS status events over wfb-ng's existing `mavlink` stream.
# We write STATUSTEXT frames to this local UDP port; wfb-ng's wfb_tx
# picks them up and sends them over the radio. The GS reads them at
# its own local mavlink port (14550 by default, per wfb-ng master.cfg).
# Set mavlink_enable = 0 if you're not running wfb-ng's mavlink stream.
#
# mavlink_sysid / mavlink_compid identify us on the MAVLink bus.
# Defaults are in the "unassigned" ranges — they won't collide with
# typical flight-controller sysid=1 / MAV_COMP_ID_AUTOPILOT1=1.
mavlink_enable   = 1
mavlink_addr     = 127.0.0.1
mavlink_port     = 14560
mavlink_sysid    = 250
mavlink_compid   = 191

# ---- Debug suite (Phase 3) ------------------------------------------
# Master switch and per-feature overrides for the post-flight debug
# tooling. Production flights leave debug_enable = 0.
#
# Per-feature flags use a tristate: -1 = follow debug_enable,
# 0 = force off, 1 = force on.
debug_enable     = 0
dbg_log_enable   = -1

# GS-side endpoint for drone→GS tunnel traffic (PONG packets, future
# debug back-channel). Mirrors the GS's `wfb_ng.drone_addr/drone_port`
# pair: GS at 10.5.0.1 listens on `gs_tunnel_port` for tunnel traffic.
gs_tunnel_addr   = 10.5.0.1
gs_tunnel_port   = 5801

# SD-card failure log. Append-only JSONL. No-op if the directory is not
# mounted/writable (logged once at startup).
dbg_log_dir      = /sdcard/dl-events
dbg_max_bytes    = 33554432
dbg_fsync_each   = 0

# --- P4a: drone→GS config handshake ----------------------------------
# Authoritative sources for MTU and FPS, read once at startup.
# MTU comes from /etc/wfb.yaml `wireless.mlink` (typically 1400 or
# 3994 depending on wfb-ng's radio_mtu setting). FPS comes from
# /etc/majestic.yaml `video0.fps`.
hello_wfb_yaml_path = /etc/wfb.yaml
hello_majestic_yaml_path = /etc/majestic.yaml

# Cadence of the DLHE announce. The first
# `hello_announce_initial_count` retries use the "initial" delay;
# after that the "steady" delay is used until an ACK arrives.
hello_announce_initial_ms    = 500
hello_announce_steady_ms     = 5000
hello_announce_initial_count = 60
# Once ACKed, DLHE is sent every `hello_keepalive_ms` to keep the
# GS aware. Three missed keepalive ACKs drop back to ANNOUNCING.
hello_keepalive_ms = 10000
