# Dev container for wfb-ng-interleav
# Contains all C/Python build + test deps and Claude Code pre-configured
# to run with permissions bypassed (safe: intended for use inside a container).

FROM debian:bookworm

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1

# ---- Build + test dependencies (C and Python) --------------------------------
# C deps mirror docker/Dockerfile.debian: libpcap, libsodium, libevent,
# gstreamer-rtsp-server. Python deps cover twisted.trial test runner plus
# the imports used by wfb_ng.tests (twisted, pyroute2, msgpack, serial).
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake pkg-config git wget curl ca-certificates \
        gnupg lsb-release sudo gosu vim less \
        libpcap-dev libsodium-dev libevent-dev \
        libgstrtspserver-1.0-dev \
        python3 python3-pip python3-dev python3-setuptools python3-wheel \
        python3-virtualenv python3-twisted python3-pyroute2 \
        python3-serial python3-msgpack \
        fakeroot debhelper dh-python \
        procps net-tools iproute2 iputils-ping iw \
    && rm -rf /var/lib/apt/lists/*

# Catch2 v3.7.1 (same version the deb/rpm builder uses; Debian bookworm
# ships 3.4 which is not enough for the project's test sources).
RUN cd /tmp && git clone --depth 1 -b v3.7.1 https://github.com/catchorg/Catch2.git \
 && cd Catch2 && cmake -Bbuild -H. -DBUILD_TESTING=OFF \
 && cmake --build build/ --target install -j"$(nproc)" \
 && rm -rf /tmp/Catch2

# ---- Node.js + Claude Code ---------------------------------------------------
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y --no-install-recommends nodejs \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g @anthropic-ai/claude-code

# Pre-configure Claude Code to bypass the permission prompt for every tool.
# This is fine here because the image is meant to be run inside a throwaway
# container where the blast radius is limited to the mounted workspace.
# The entrypoint copies this template into the runtime user's HOME.
COPY claude-settings.json /etc/claude-settings.json

# Entrypoint creates a user matching HOST_UID/HOST_GID so files written to the
# bind-mounted /workspace keep the host user's ownership.
COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

WORKDIR /workspace
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
